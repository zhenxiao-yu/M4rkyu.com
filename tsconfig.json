{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": [
      "node",
      "react",
      "react-dom"
    ],
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.mts",
    ".next/dev/types/**/*.ts",
    ".next/types/**/*.ts",
    ".next-node22/dev/types/**/*.ts",
    ".next-node22/types/**/*.ts",
    ".next-dev-*/types/**/*.ts",
    ".next-playwright/types/**/*.ts",
    ".next-dev/types/**/*.ts",
    ".next-dev/dev/types/**/*.ts",
    ".next-validate/types/**/*.ts",
    ".next-validate/dev/types/**/*.ts",
    ".next-postpolish/types/**/*.ts",
    ".next-postpolish/dev/types/**/*.ts",
    ".next-p2/types/**/*.ts",
    ".next-p2/dev/types/**/*.ts",
    ".next-p2b/types/**/*.ts",
    ".next-p2b/dev/types/**/*.ts",
    ".next-conn/types/**/*.ts",
    ".next-conn/dev/types/**/*.ts",
    ".next-fastemail/types/**/*.ts",
    ".next-fastemail/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
