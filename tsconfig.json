{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowImportingTsExtensions": true,
    "types": [
      "node",
      "react",
      "react-dom"
    ],
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.mts",
    ".next/dev/types/**/*.ts",
    ".next/types/**/*.ts",
    ".next-playwright/types/**/*.ts",
    ".next-playwright/dev/types/**/*.ts",
    ".next-verify/types/**/*.ts",
    ".next-verify/dev/types/**/*.ts",
    ".next-verify-build/types/**/*.ts",
    ".next-verify-build/dev/types/**/*.ts",
    ".next-vcheck/types/**/*.ts",
    ".next-vcheck/dev/types/**/*.ts",
    ".next-budgets/types/**/*.ts",
    ".next-budgets/dev/types/**/*.ts",
    ".next-ts6-verify/types/**/*.ts",
    ".next-ts6-verify/dev/types/**/*.ts",
    ".next-aisearch-verify/types/**/*.ts",
    ".next-aisearch-verify/dev/types/**/*.ts",
    ".next-dev-3216/types/**/*.ts",
    ".next-dev-3216/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
