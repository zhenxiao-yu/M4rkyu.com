    "locomotive-scroll": "^4.1.1",
    "next": "^14.2.12",
    "normalize.css": "^8.0.1",
    "react": "^18.2.0",
    "react-animated-cursor": "^2.11.2",
    "react-dom": "^18.2.0",
    "react-helmet": "^6.1.0",
    "react-icons": "^4.12.0",
    "react-loader-spinner": "^6.1.6",
    "react-responsive-masonry": "^2.2.1",
    "react-router-dom": "^5.2.0",
    "react-scroll": "^1.9.0",
    "react-simple-typewriter": "^5.0.1",
    "react-tilt": "^1.0.2",
    "react-vertical-timeline-component": "^3.6.0",
