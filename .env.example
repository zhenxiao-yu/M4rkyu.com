# Firebase Web SDK config — these are PUBLIC by design.
# The web SDK needs them at runtime to address the project; access
# control lives in Firebase Security Rules, not in the secrecy of
# these values. Safe to commit (this example file) and to ship to
# the client bundle (the NEXT_PUBLIC_ prefix is intentional).
#
# Copy this file to `.env` and fill in the values from the Firebase
# console (Project settings → Your apps → SDK setup and configuration).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ── Inquiry pipeline (server actions in src/app/[locale]/contact) ──
#
# Resend powers transactional email for the /contact form. Create an
# API key at https://resend.com/api-keys. Verify the sender domain
# (or use the `onboarding@resend.dev` sandbox sender in dev).
#
# INQUIRY_FROM_EMAIL must be on a verified domain for production —
# unverified senders are rejected with a 422 from Resend.
RESEND_API_KEY=
INQUIRY_FROM_EMAIL=
INQUIRY_TO_EMAIL=

# ── Resend webhook (optional) ──
#
# When set, /api/webhooks/resend verifies incoming events using
# svix-style HMAC-SHA256 signatures and logs the result (delivered,
# bounced, complained, opened, clicked).
#
# Create at https://resend.com/webhooks → Add Endpoint
# (URL: https://m4rkyu.com/api/webhooks/resend). Resend shows the
# "Signing Secret" once on creation — paste it here. When unset,
# the route returns 503 and skips processing.
RESEND_WEBHOOK_SECRET=

# ── Cloudflare Turnstile (spam protection) ──
#
# Optional. When both keys are set, the contact form renders the
# Turnstile widget and the server action verifies the token before
# calling Resend. When unset, the form falls back to the honeypot
# check only — fine for local dev.
#
# Create a site at https://dash.cloudflare.com → Turnstile.
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
