# ── Supabase (auth + user content backend) ──
#
# These power the user system: OAuth login, profiles, saved items,
# and moderated comments. Create a project at
# https://supabase.com/dashboard/projects → New project.
#
# Project settings → API → URL and anon key are SAFE to expose to the
# browser (RLS is the actual guard). The service role key is server-only
# and MUST NEVER ship to the client bundle — see src/lib/env.ts.
#
# Setup steps (see docs/BACKEND_ARCHITECTURE.md §13 and supabase/README.md):
#   1. Create the project, paste URL + anon key below.
#   2. Run the SQL migrations in supabase/migrations/ in order.
#   3. Authentication → Providers: enable Google, GitHub, Email (magic link).
#   4. Authentication → URL Configuration:
#        Site URL: https://m4rkyu.com  (or http://localhost:3000 in dev)
#        Redirect URLs:
#          https://m4rkyu.com/auth/callback
#          http://localhost:3000/auth/callback
#   5. After your first sign-in, promote yourself to admin via SQL
#      (see supabase/README.md "First admin").
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Set to "false" to hide the corresponding OAuth button. When unset,
# Google, GitHub, and Discord are shown once Supabase public config is present.
# Email + password and magic link are always on once Supabase auth is
# configured.
NEXT_PUBLIC_AUTH_GOOGLE_ENABLED=
NEXT_PUBLIC_AUTH_GITHUB_ENABLED=
NEXT_PUBLIC_AUTH_DISCORD_ENABLED=
# Optional. Server-only. Bypasses RLS.
#
# When set together with RESEND_API_KEY + INQUIRY_FROM_EMAIL, magic-
# link sign-in emails are minted via `auth.admin.generateLink` and
# delivered through Resend instead of Supabase's built-in SMTP. That
# drops typical delivery from 30–60s (Supabase default) to 2–5s.
# Without this key the slower built-in pipeline is used — both
# paths produce identical sign-in flows otherwise.
#
# Also enables admin-only operations that explicitly call
# `getAdminSupabaseClient()`. Never imported into a "use client"
# file; the `import "server-only"` guard on src/lib/supabase/admin.ts
# turns that into a build error.
SUPABASE_SERVICE_ROLE_KEY=

# Public site origin. Used to build OAuth redirect URLs server-side so
# the callback works in dev (localhost) and prod (m4rkyu.com) without
# code changes. Leave empty in production builds on Vercel — the
# VERCEL_URL env var is consulted as a fallback.
NEXT_PUBLIC_SITE_URL=

# ── Legacy / unused ──
# Firebase Web SDK config — kept as orphans for now. Not referenced by
# any code in this repo (Supabase replaced the auth/data layer). Safe
# to delete once you've confirmed no preview deploy depends on them.
# Firebase Web SDK config — these are PUBLIC by design.
# The web SDK needs them at runtime to address the project; access
# control lives in Firebase Security Rules, not in the secrecy of
# these values. Safe to commit (this example file) and to ship to
# the client bundle (the NEXT_PUBLIC_ prefix is intentional).
#
# Copy this file to `.env` and fill in the values from the Firebase
# console (Project settings → Your apps → SDK setup and configuration).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ── Inquiry pipeline (server actions in src/app/[locale]/contact) ──
#
# Resend powers transactional email for the /contact form. Create an
# API key at https://resend.com/api-keys. Verify the sender domain
# (or use the `onboarding@resend.dev` sandbox sender in dev).
#
# INQUIRY_FROM_EMAIL must be on a verified domain for production —
# unverified senders are rejected with a 422 from Resend.
RESEND_API_KEY=
INQUIRY_FROM_EMAIL=
INQUIRY_TO_EMAIL=

# ── Resend webhook (optional) ──
#
# When set, /api/webhooks/resend verifies incoming events using
# svix-style HMAC-SHA256 signatures and logs the result (delivered,
# bounced, complained, opened, clicked).
#
# Create at https://resend.com/webhooks → Add Endpoint
# (URL: https://m4rkyu.com/api/webhooks/resend). Resend shows the
# "Signing Secret" once on creation — paste it here. When unset,
# the route returns 503 and skips processing.
RESEND_WEBHOOK_SECRET=

# ── Cloudflare Turnstile (spam protection) ──
#
# Optional. When both keys are set, the contact form renders the
# Turnstile widget and the server action verifies the token before
# calling Resend. When unset, the form falls back to the honeypot
# check only — fine for local dev.
#
# Create a site at https://dash.cloudflare.com → Turnstile.
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
